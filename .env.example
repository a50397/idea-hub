# Database
DATABASE_URL="mongodb://mongodb:27017/ideahub"

# Auth — SESSION_SECRET is required. Generate one with: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
SESSION_SECRET=
NODE_ENV="development"
COOKIE_SECURE="false"

# Default Admin (required on first run if no admin exists)
# Change these from defaults before running!
ADMIN_EMAIL=
ADMIN_PASSWORD=
ADMIN_NAME="Admin"

# Backend
BACKEND_PORT=3001

# Frontend
VITE_API_URL="http://localhost:3001"
